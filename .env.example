# Copy to .env and fill in. NEVER commit .env or your SSH key.

# ---- Phoenix ERP mock (URL + your team token are on Builder Base) ----
PHOENIX_API_BASE_URL=https://REPLACE-with-the-phoenix-url-from-builder-base
PHOENIX_API_TOKEN=replace-with-your-team-token

# ---- SSH access to the customer VMs ----
# Put your .pem in ./keys/ (mounted read-only at /keys) and point this at it.
SSH_PRIVATE_KEY_PATH=/keys/your-key.pem
SSH_USERNAME=azureuser

# ---- LLM (optional, bring-your-own) ----
# No LLM / Azure OpenAI credentials are provided. If your agent uses an LLM,
# supply your OWN provider's keys here, e.g.:
#   OPENAI_API_KEY=...
#   OPENAI_MODEL=gpt-4o

# ---- PostgreSQL ----
POSTGRES_USER=autopilot
POSTGRES_PASSWORD=change_me_before_running
POSTGRES_DB=autopilot
# Used by SQLAlchemy inside the container; swap "postgres" -> "localhost" for local dev outside Docker
DATABASE_URL=postgresql+asyncpg://autopilot:change_me_before_running@postgres:5432/autopilot

# ---- LLM ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ---- Frontend ----
VITE_API_BASE=http://localhost:8000
